# Test runner image for playAIdes.
# Everything needed to run pytest (unit + integration + live) lives here.
# Nothing needs to be installed on the host.
FROM python:3.12-slim

# No system libs needed for the test suite — we lazy-import sounddevice only
# in the live-playback path, which tests do not exercise.

WORKDIR /app

# Copy project metadata first for better layer caching.
COPY pyproject.toml README.md ./

# Install runtime + dev deps. We only have pyproject.toml at this point; the
# actual source is bind-mounted at runtime by docker-compose, so an editable
# install would fail here. Install deps directly.
RUN pip install --no-cache-dir \
    "pydantic>=2.0" \
    "requests>=2.31" \
    "fastapi>=0.110" \
    "python-multipart>=0.0.9" \
    "uvicorn>=0.27" \
    "httpx>=0.27" \
    "websockets>=12" \
    "pytest>=8.0" \
    "pytest-asyncio>=0.23" \
    "pytest-cov>=5.0" \
    "responses>=0.25" \
    "respx>=0.21"

# Non-root user so mounted files keep sane ownership.
RUN useradd --create-home --shell /bin/bash tester
USER tester

# The repo is bind-mounted at /app at runtime; /out is writable for coverage artifacts.
ENV PYTHONPATH=/app \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

CMD ["pytest"]
