# Copy this to .env and edit the values you need. Compose auto-loads .env.
# Do NOT commit .env (already gitignored).

# ─ Home Assistant integration ────────────────────────────────────────────
# Required for any HA feature. Leave empty to disable HA.
HA_URL=
HA_TOKEN=
HA_DEFAULT_AGENT_ID=

# ─ Bearer token HA must send to playAIdes endpoints ──────────────────────
# Unset = dev mode (no auth check, with startup warning). Set to anything
# random in shared deployments.
PLAYAIDES_API_KEY=

# ─ LLM backend ──────────────────────────────────────────────────────────
# Any OpenAI-compatible /v1 endpoint works. Defaults below point at host
# Ollama; uncomment a different LLM_URL to switch backends.

LLM_URL=http://host.docker.internal:11434/v1     # host Ollama
LLM_MODEL=gemma3:4b

# Examples (uncomment to use):
# LLM_URL=http://host.docker.internal:8081/v1    # llamacpp-wrapper
# LLM_MODEL=gemma4-26b-q4                         # llamacpp Q4 — daily driver
# LLM_MODEL=gemma4-26b-q8                         # llamacpp Q8 — quality (single-concurrency only)
